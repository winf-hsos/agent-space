# Copy this file to ".env" and fill in real values. Do NOT commit/share .env.
#
# One token per bot. The variable name must match the `token_env` of a bot in
# bots.yaml. Allowed users and working directories live in bots.yaml, not here.

# Token for the example chit-chat bot (from @BotFather)
EXAMPLE_BOT_TOKEN=123456:ABC-your-token-here

# Add one line per additional bot, matching its token_env in bots.yaml, e.g.:
# WIKI_BOT_TOKEN=123456:ABC-another-token

# Required only if you want voice-message transcription (OpenAI Whisper API)
# OPENAI_API_KEY=sk-...
# Optional: transcription model (default: whisper-1)
# TRANSCRIBE_MODEL=whisper-1

# Optional: explicit path to the opencode executable (otherwise auto-detected)
# OPENCODE_BIN=C:\Users\you\AppData\Roaming\npm\node_modules\opencode-ai\bin\opencode.exe

# Agent invocation logging: set to 1 to log every prompt + raw opencode output.
# Logs go to agent-telegram-bridge/logs/<agent>.log by default.
# AGENT_LOG=1
# AGENT_LOG_DIR=C:\path\to\custom\log\folder

# Auto-update: poll GitHub and restart the bridge when new commits arrive.
# Set on the server only — leave unset (or 0) on dev machines.
# AUTO_UPDATE_INTERVAL=300
#
# Optional: also pull a second repo (e.g. your private agents repo).
# Leave unset if your agents are not on GitHub or you manage them manually.
# AUTO_UPDATE_AGENTS_DIR=C:\path\to\my-agents
